---
import "@/styles/global.css";
import NavTree from "@/components/NavTree";
import MobileNav from "@/components/MobileNav";
import type { NavEntry } from "@/components/NavTree";
import { ClientRouter } from "astro:transitions";
import Header from "@/components/Header.astro";

interface Props {
  title: string;
  entries: NavEntry[];
  currentPath: string;
  headings?: any[];
}

const { title, entries, currentPath, headings } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${title} - Wiki D&D 2024`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Wiki D&D 2024</title>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="flex min-h-screen">
      <ClientRouter />
      <!-- Sidebar (desktop) -->
      <aside
        class="hidden lg:flex lg:w-72 lg:flex-col lg:fixed lg:inset-y-0 lg:z-30 border-r border-border bg-card"
      >
        <div class="flex h-14 items-center border-b border-border px-4">
          <a
            href="/wiki"
            class="flex items-center gap-2 font-bold text-lg tracking-tight hover:opacity-80 transition-opacity"
          >
            <span class="text-xl">📜</span>
            <span
              class="bg-linear-to-r from-primary to-accent bg-clip-text text-transparent"
            >
              Wiki D&D
            </span>
          </a>
        </div>
        <div class="flex-1 overflow-hidden">
          <NavTree
            entries={entries}
            currentPath={currentPath}
            currentHeadings={headings}
            client:only="react"
          />
        </div>
      </aside>

      <!-- Main content area -->
      <div class="flex flex-1 flex-col lg:pl-72">
        <!-- Header (mobile) -->
        <Header
          title={title}
          entries={entries}
          currentPath={currentPath}
          headings={headings}
        />

        <!-- Content -->
        <main class="flex-1 p-6 lg:p-10 max-w-4xl">
          <article
            class="prose prose-base prose-primary dark:prose-invert max-w-none"
          >
            <slot />
          </article>
        </main>
      </div>
    </div>
  </body>
</html>
